# Copy to `.env.local` and fill in real values (`.env.local` is gitignored).

# Cloudinary — Dashboard → Settings → Product environment credentials (cloud name)
# Upload → Upload presets → Add → Signing: Unsigned (for browser uploads from this POC)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Optional: Cloudinary Admin API credentials (required to delete uploaded images)
# NOTE: putting secrets in a frontend bundle is not secure; use only for this POC.
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=

# Optional API keys (can also be set in the app UI)
VITE_NANOBANANA_API_KEY=

# Gemini API (native image — multimodal, like gemini.google.com)
# VITE_GEMINI_API_KEY=
# Optional: defaults to gemini-3.1-flash-image-preview. Alternatives: gemini-3-pro-image-preview (best), gemini-2.5-flash-image (fastest)
# VITE_GEMINI_IMAGE_MODEL=
# VITE_GEMINI_API_BASE=

# Vertex AI (Imagen) — optional; usually set Project ID + OAuth token in the app UI
# VITE_VERTEX_PROJECT_ID=
# VITE_VERTEX_LOCATION=us-central1
# VITE_VERTEX_ACCESS_TOKEN=
# VITE_VERTEX_API_KEY=
# Optional model overrides (defaults: imagen-4.0-fast-generate-001 text-to-image, imagen-3.0-capability-001 inpaint)
# VITE_VERTEX_TEXT_MODEL=
# VITE_VERTEX_EDIT_MODEL=
